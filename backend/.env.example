# Copy to .env and fill in your keys. Do not commit .env.

# Google Gemini — at least one of these (see ai_service.py for fallback order)
GEMINI_API_KEY=
GEMINI_API_KEY_CONTENT=
GEMINI_API_KEY_DESIGN=

# Optional: split keys / aliases used by ai_service
# GEMINI_KEY_1=
# GEMINI_KEY_2=

# Set to 'true' to bypass API calls and return mock data
DEV_MODE=false

# Model routing — uncomment/adjust; restart server after changes
GEMINI_CONTENT_MODEL=gemini-2.5-flash-lite
GEMINI_DESIGN_MODEL=gemini-2.5-flash-lite
# GEMINI_MIN_GAP_SECONDS=0.45
# PERF_LOG=true
# GEMINI_PRIMARY_MODEL=
# GEMINI_FALLBACK_MODELS=
# GEMINI_MODEL_BLOCKLIST=

# API Ninjas — Emoji API (https://api.api-ninjas.com/api/emoji)  Header: X-Api-Key
# Alias: EMOJI_API_KEY
API_NINJAS_KEY=
EMOJI_API_KEY=

# Pexels — backgrounds (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Optional: persist Gemini JSON under backend/cache/
# ENABLE_DISK_CACHE=true

# CORS origins for frontend deployment (comma-separated; no trailing slash)
# FRONTEND_ORIGINS=https://your-frontend.onrender.com,https://www.yourdomain.com
